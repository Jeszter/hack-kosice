# ========== SECURITY ==========
# JWT secret — generate with: openssl rand -hex 32
JWT_SECRET=change_me_to_32_char_random_string_for_production

# ========== EMAIL ==========
# provider: "resend" (production) or "smtp" (dev, uses MailHog)
EMAIL_PROVIDER=resend

# Resend API key (get from https://resend.com/api-keys)
RESEND_API_KEY=

# From address (must be verified in Resend)
EMAIL_FROM=onboarding@resend.dev
EMAIL_FROM_NAME=EquiPay

# ========== AI (OpenRouter) ==========
# Get your key at https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash

# ========== TATRA BANKA PSD2 ==========
# Register as TPP at https://developer.tatrabanka.sk
TATRA_API_KEY=
TATRA_SANDBOX=true

# ========== JWT TOKENS ==========
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=30

# ========== DEV-ONLY ==========
# These are overridden in docker-compose.yml — no need to change here
# DB_URL=jdbc:postgresql://localhost:5432/equipay
# DB_USER=equipay
# DB_PASSWORD=equipay_dev_pwd
# REDIS_URL=redis://localhost:6379
